---
interface Props {
  scenario?: string;
  height?: string;
  docs?: boolean;
  wasmBaseUrl?: string;
  vscodeAssetsUrl?: string;
}

const {
  scenario = "counter",
  height,
  docs = false,
  wasmBaseUrl = assetPath("wasm/"),
  vscodeAssetsUrl = assetPath("vscode/"),
} = Astro.props;

function assetPath(path: string): string {
  const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\/+/, "")}`;
}
---

<script>
  import "./vizsla-lab";
</script>

{
  docs ? (
    <vizsla-lab
      docs
      scenario={scenario}
      height={height}
      wasm-base-url={wasmBaseUrl}
      vscode-assets-url={vscodeAssetsUrl}
    ></vizsla-lab>
  ) : (
    <vizsla-lab
      scenario={scenario}
      height={height}
      wasm-base-url={wasmBaseUrl}
      vscode-assets-url={vscodeAssetsUrl}
    ></vizsla-lab>
  )
}
